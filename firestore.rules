rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasValidCharacterProgress() {
      return !('character' in request.resource.data)
             || (request.resource.data.character.gold >= 0
                 && request.resource.data.character.level >= 1);
    }

    match /users/{userId} {
      allow read, create, delete: if isOwner(userId);

      allow update: if isOwner(userId) && hasValidCharacterProgress();
    }

    match /users/{userId}/_meta/{doc} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
