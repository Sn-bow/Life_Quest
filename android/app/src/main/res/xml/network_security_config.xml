<?xml version="1.0" encoding="utf-8"?>
<!-- Disallows cleartext (HTTP) traffic in release builds.
     Firebase, AdMob, and all app network calls use HTTPS only. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
